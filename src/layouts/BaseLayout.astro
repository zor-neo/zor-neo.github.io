---
interface Props { title: string; description: string; }
const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#f2eee5" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&family=Newsreader:opsz,wght@6..72,400;6..72,500&display=swap" rel="stylesheet" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/social-card.svg', Astro.site)} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/social-card.svg', Astro.site)} />
		<title>{title}</title>
	</head>
	<body><a class="skip-link" href="#main">Skip to content</a><slot /></body>
</html>

<style is:global>
	:root { --paper:#f2eee5; --paper-deep:#e9e3d8; --ink:#1d1b17; --muted:#6e685f; --line:rgba(29,27,23,.15); --line-strong:rgba(29,27,23,.32); --signal:#a24c31; --serif:'Newsreader',Georgia,serif; --sans:'DM Sans',Arial,sans-serif; color-scheme:light; }
	* { box-sizing:border-box; }
	html { background:var(--paper); scroll-behavior:smooth; }
	body { background:linear-gradient(rgba(29,27,23,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(29,27,23,.018) 1px,transparent 1px),var(--paper); background-size:100% 4rem,4rem 100%,auto; color:var(--ink); font-family:var(--sans); margin:0; min-width:320px; }
	::selection { background:var(--ink); color:var(--paper); }
	a:focus-visible { border-radius:.1rem; outline:2px solid var(--signal); outline-offset:.35rem; }
	.skip-link { background:var(--ink); color:var(--paper); left:1rem; padding:.7rem 1rem; position:fixed; top:-5rem; transition:top 150ms ease; z-index:100; }
	.skip-link:focus { top:1rem; }
	.container { margin:0 auto; max-width:1240px; padding-left:clamp(1.2rem,4vw,4rem); padding-right:clamp(1.2rem,4vw,4rem); }
	.section-label { align-items:center; color:var(--muted); display:flex; font-size:.68rem; font-weight:700; gap:1rem; letter-spacing:.15em; margin:0; text-transform:uppercase; }
	.section-label::before { background:var(--signal); content:''; height:.42rem; width:.42rem; }
	.sr-only { height:1px; margin:-1px; overflow:hidden; padding:0; position:absolute; width:1px; clip:rect(0,0,0,0); white-space:nowrap; }
	@media (prefers-reduced-motion:reduce) { * { scroll-behavior:auto !important; transition-duration:.001ms !important; } }
</style>

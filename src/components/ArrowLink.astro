---
interface Props { href: string; label: string; }
const { href, label } = Astro.props;
const external = href.startsWith('http');
---

<a href={href} target={external ? '_blank' : undefined} rel={external ? 'noreferrer' : undefined}>
	{label}<span aria-hidden="true">↗</span>
</a>

<style>
	a { align-items: center; color: var(--ink); display: inline-flex; font-size: 0.78rem; font-weight: 700; gap: 0.45rem; letter-spacing: 0.05em; text-decoration: none; text-transform: uppercase; }
	span { display: inline-block; transition: transform 180ms ease; }
	a:hover span, a:focus-visible span { transform: translate(0.15rem, -0.15rem); }
</style>
